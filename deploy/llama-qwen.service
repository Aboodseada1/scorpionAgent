[Unit]
Description=llama.cpp server — Qwen2.5-1.5B-Instruct Q4_K_M (local LLM for agent)
After=network.target

[Service]
Type=simple
User=root
Group=root
Environment=LD_LIBRARY_PATH=/opt/llama/llama-b8746
WorkingDirectory=/opt/llama/llama-b8746
ExecStart=/opt/llama/llama-b8746/llama-server \
  -m /var/www/agent.scorpion.codes/models/qwen2.5-1.5b-instruct-q4km/Qwen2.5-1.5B-Instruct-Q4_K_M.gguf \
  --host 127.0.0.1 \
  --port 18080 \
  -c 2048 \
  -t 3
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
